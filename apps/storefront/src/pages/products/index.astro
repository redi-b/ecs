---
import StoreUnavailable from "../../components/shell/StoreUnavailable.astro";
import { listStoreCategories, listStoreCollections } from "../../lib/commerce/catalog";
import { listStoreProducts } from "../../lib/commerce/products";
import { isStoreError } from "../../lib/commerce/result";
import type { StoreCategory, StoreCollection, StoreProduct } from "../../lib/commerce/types";
import { loadPageContext } from "../../lib/page-context";
import { getPrimaryColor, themeFromTokens } from "../../lib/theme";
import { resolveRendererSlot } from "../../templates/registry";

const ctx = await loadPageContext(Astro.request);
if (!ctx.ok) {
  Astro.response.status = ctx.status;
}

const limit = 24;
const offset = Math.max(0, Number(Astro.url.searchParams.get("offset") ?? "0") || 0);
const q = Astro.url.searchParams.get("q")?.trim() || "";
const collectionId = Astro.url.searchParams.get("collection")?.trim() || "";
const categoryId = Astro.url.searchParams.get("category")?.trim() || "";
const order = Astro.url.searchParams.get("order")?.trim() || "";

const productsResult = ctx.ok
  ? await listStoreProducts({
      platformApiBaseUrl: ctx.platformApiBaseUrl,
      requestHost: ctx.requestHost,
      regionId: ctx.config.commerce.regionId,
      limit,
      offset,
      q: q || null,
      collectionId: collectionId || null,
      categoryId: categoryId || null,
      order: order || null,
    })
  : null;

const collectionsResult = ctx.ok
  ? await listStoreCollections({
      platformApiBaseUrl: ctx.platformApiBaseUrl,
      requestHost: ctx.requestHost,
      limit: 50,
    })
  : null;

const categoriesResult = ctx.ok
  ? await listStoreCategories({
      platformApiBaseUrl: ctx.platformApiBaseUrl,
      requestHost: ctx.requestHost,
      limit: 100,
    })
  : null;

const products: StoreProduct[] =
  productsResult && !isStoreError(productsResult) ? productsResult.products : [];
const count =
  productsResult && !isStoreError(productsResult)
    ? (productsResult.count ?? products.length)
    : 0;
const errorMessage = productsResult && isStoreError(productsResult) ? productsResult.message : null;
const collections: StoreCollection[] =
  collectionsResult && !isStoreError(collectionsResult) ? collectionsResult.collections : [];
const categories: StoreCategory[] =
  categoriesResult && !isStoreError(categoriesResult) ? categoriesResult.categories : [];

const hasPrev = offset > 0;
const hasNext = offset + limit < count;

function productsHref(nextOffset: number) {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (collectionId) params.set("collection", collectionId);
  if (categoryId) params.set("category", categoryId);
  if (order) params.set("order", order);
  if (nextOffset > 0) params.set("offset", String(nextOffset));
  const qs = params.toString();
  return qs ? `/products?${qs}` : "/products";
}

const ProductList = ctx.ok
  ? resolveRendererSlot(ctx.config.storefront.templateKey, "ProductList")
  : null;
---

{
  !ctx.ok || !ProductList ? (
    <StoreUnavailable message={ctx.ok ? "Template unavailable" : ctx.message} />
  ) : (
    <ProductList
      tenantName={ctx.config.tenant.name}
      cartCount={ctx.cartCount}
      primaryColor={getPrimaryColor(ctx.config.storefront.themeTokens)}
      theme={themeFromTokens(ctx.config.storefront.themeTokens)}
      currentPath="/products"
      products={products}
      errorMessage={errorMessage}
      hasPrev={hasPrev}
      hasNext={hasNext}
      prevHref={hasPrev ? productsHref(Math.max(0, offset - limit)) : undefined}
      nextHref={hasNext ? productsHref(offset + limit) : undefined}
      collections={collections}
      categories={categories}
      filters={{
        q: q || undefined,
        collectionId: collectionId || undefined,
        categoryId: categoryId || undefined,
        order: order || undefined,
      }}
      totalCount={count}
    />
  )
}
