SERVICE_NAME=medusa
PORT=9000
DATABASE_URL=postgres://ecs:ecs@localhost:5432/medusa_db
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379
STORE_CORS=http://*.lvh.me,http://localhost:4321
ADMIN_CORS=http://dashboard.lvh.me,http://localhost:3001
AUTH_CORS=http://dashboard.lvh.me,http://localhost:3001
JWT_SECRET=
COOKIE_SECRET=
PLATFORM_INTERNAL_API_TOKEN=development-platform-internal-token
# Base URL for Medusa → platform internal notification ingest (no trailing slash)
PLATFORM_API_INTERNAL_URL=http://localhost:3000
WORKER_MODE=shared
DISABLE_MEDUSA_ADMIN=true
CHAPA_SECRET_KEY=
CHAPA_API_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=http://api.lvh.me:3000/platform/payments/chapa/callback
CHAPA_RETURN_URL=http://shop.lvh.me:4321/checkout/payment-return
CHAPA_CUSTOMIZATION_TITLE=ECS Store
CHAPA_CUSTOMIZATION_DESCRIPTION=Order payment
CHAPA_FALLBACK_EMAIL=payments@example.com
