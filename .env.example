NODE_ENV=development
PLATFORM_PUBLIC_BASE_URL=http://api.lvh.me
DASHBOARD_PUBLIC_BASE_URL=http://dashboard.lvh.me
STOREFRONT_PUBLIC_BASE_DOMAIN=lvh.me
MEDUSA_INTERNAL_URL=http://medusa:9000
PLATFORM_INTERNAL_API_TOKEN=development-platform-internal-token
# Better Auth cookie prefix (platform-api + dashboard). Default: ecs → ecs.session_token
BETTER_AUTH_COOKIE_PREFIX=ecs
REDIS_URL=redis://localhost:6379
# Merchant notifications (platform-api + worker). Optional; unset → log provider.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Resend email. Both RESEND_API_KEY and EMAIL_FROM required for real delivery.
RESEND_API_KEY=
EMAIL_FROM=
MEDIA_STORAGE_PROVIDER=s3
MEDIA_S3_ENDPOINT=http://localhost:9002
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=ecs-media
MEDIA_S3_ACCESS_KEY_ID=ecs
MEDIA_S3_SECRET_ACCESS_KEY=ecs-media-development
MEDIA_S3_PUBLIC_BASE_URL=http://localhost:9002/ecs-media
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MINIO_ROOT_USER=ecs
MINIO_ROOT_PASSWORD=ecs-media-development
MINIO_BUCKET=ecs-media
MINIO_API_HOST_PORT=9002
MINIO_CONSOLE_HOST_PORT=9003
# Chapa: platform-api uses CHAPA_SECRET_KEY + PLATFORM_PUBLIC_BASE_URL for
# callback_url (/platform/payments/chapa/callback). Always re-verifies via API.
# CHAPA_CALLBACK_URL / CHAPA_RETURN_URL are legacy commerce defaults (storefront).
CHAPA_SECRET_KEY=
CHAPA_API_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=http://api.lvh.me:3000/platform/payments/chapa/callback
CHAPA_RETURN_URL=http://shop.lvh.me:4321/checkout/payment-return
CHAPA_CUSTOMIZATION_TITLE=ECS Store
CHAPA_CUSTOMIZATION_DESCRIPTION=Order payment
CHAPA_FALLBACK_EMAIL=payments@example.com
# Optional worker schedules (also set on apps/platform-api/.env for the worker process)
BILLING_RECONCILE_INTERVAL_MS=300000
BILLING_LIFECYCLE_INTERVAL_MS=3600000
