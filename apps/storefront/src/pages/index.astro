---
import type { StoreProduct } from "../lib/platform-store";
import { listStoreProducts } from "../lib/platform-store";

const requestHost =
  Astro.request.headers.get("x-forwarded-host") ?? Astro.request.headers.get("host");
const storeResult = await listStoreProducts({
  platformApiBaseUrl: process.env.PLATFORM_API_BASE_URL ?? "http://localhost:3000",
  requestHost,
});
// biome-ignore lint/correctness/noUnusedVariables: Used by the Astro template below.
const storeError = "message" in storeResult ? storeResult : null;
// biome-ignore lint/correctness/noUnusedVariables: Used by the Astro template below.
const products: StoreProduct[] = "products" in storeResult ? storeResult.products : [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Abebe Market</title>
  </head>
  <body>
    <main>
      <section class="hero">
        <p class="eyebrow">Abebe Market</p>
        <h1>Fresh products from a local shop</h1>
        <p class="lede">
          Browse the storefront through the platform facade. Tenant context is resolved from
          the shop domain.
        </p>
      </section>

      <section class="products" aria-labelledby="products-title">
        <div class="section-heading">
          <h2 id="products-title">Products</h2>
          {!storeError && <p>{products.length} available</p>}
        </div>

        {
          storeError ? (
            <div class="notice" role="status">
              <h3>Store API is not ready</h3>
              <p>
                The platform tenant resolved, but the commerce backend returned:{" "}
                {storeError.message}.
              </p>
            </div>
          ) : products.length > 0 ? (
            <ul class="product-grid">
              {products.map((product) => (
                <li class="product">
                  {product.thumbnail ? (
                    <img src={product.thumbnail} alt="" loading="lazy" />
                  ) : (
                    <div class="product-image" aria-hidden="true" />
                  )}
                  <h3>{product.title ?? "Untitled product"}</h3>
                  {product.description && <p>{product.description}</p>}
                </li>
              ))}
            </ul>
          ) : (
            <div class="notice" role="status">
              <h3>No products yet</h3>
              <p>The storefront connection is working, but Medusa returned an empty catalog.</p>
            </div>
          )
        }
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #f8fafc;
    color: #111827;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  main {
    margin: 0 auto;
    max-width: 1120px;
    padding: 56px 20px;
  }

  .hero {
    max-width: 720px;
    padding: 32px 0 48px;
  }

  .eyebrow {
    color: #0f766e;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4.75rem);
    line-height: 0.98;
    letter-spacing: 0;
    margin-bottom: 20px;
  }

  .lede {
    color: #4b5563;
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 620px;
  }

  .section-heading {
    align-items: end;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .section-heading h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .section-heading p {
    color: #64748b;
    margin: 0;
  }

  .product-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .product,
  .notice {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 16px;
  }

  .product img,
  .product-image {
    aspect-ratio: 4 / 3;
    background: #dbeafe;
    border-radius: 6px;
    display: block;
    margin-bottom: 14px;
    object-fit: cover;
    width: 100%;
  }

  .product h3,
  .notice h3 {
    font-size: 1rem;
    margin-bottom: 8px;
  }

  .product p,
  .notice p {
    color: #4b5563;
    line-height: 1.6;
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    main {
      padding-top: 32px;
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
