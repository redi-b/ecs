{
	admin off
	auto_https off
	servers {
		trusted_proxies static private_ranges
		trusted_proxies_strict
	}
}

# Hashed Next.js build assets — safe to cache for a year.
# Do not apply this to /admin HTML or API (cookie-auth; no-store).
(next_static_cache) {
	header Cache-Control "public, max-age=31536000, immutable"
}

:80 {
	encode zstd gzip
	log {
		output stdout
		format console
	}
	log_skip /healthz

	respond /healthz 200

	@platform host api.{$BASE_DOMAIN}
	handle @platform {
		reverse_proxy platform-api:3000
	}

	@dashboard host dashboard.{$BASE_DOMAIN}
	handle @dashboard {
		@next_static path /_next/static/*
		handle @next_static {
			import next_static_cache
			reverse_proxy dashboard:3001
		}

		handle {
			reverse_proxy dashboard:3001
		}
	}

	# Public object reads for media uploads (path-style bucket URLs).
	@media host media.{$BASE_DOMAIN}
	handle @media {
		# Product thumbs / library assets are content-addressed or infrequently overwritten.
		header Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
		reverse_proxy minio:9000
	}

	@storefront host *.{$BASE_DOMAIN}
	handle @storefront {
		@next_static path /_next/static/*
		handle @next_static {
			import next_static_cache
			reverse_proxy dashboard:3001
		}

		@dashboard_assets path /_next/* /__nextjs* /favicon.ico
		handle @dashboard_assets {
			reverse_proxy dashboard:3001
		}

		@admin path /admin*
		handle @admin {
			reverse_proxy dashboard:3001
		}

		@api path /api/*
		handle @api {
			uri strip_prefix /api
			reverse_proxy platform-api:3000
		}

		handle {
			reverse_proxy storefront:4321
		}
	}

	respond 404
}
