---
import type {
  StorefrontError,
  StoreProduct,
  StoreProductsResponse,
} from "../../../lib/platform-store";
import { listStoreCollections } from "../../../lib/commerce/catalog";
import { isStoreError } from "../../../lib/commerce/result";
import { formatMoney } from "../../../lib/money";
import Layout from "./Layout.astro";
import {
  classicShellTheme,
  isImageUrl,
  parseClassicData,
  parseClassicTheme,
} from "./lib";

interface Props {
  data: unknown;
  productsResult: StoreProductsResponse | StorefrontError;
  tenantName: string;
  themeTokens: unknown;
  platformApiBaseUrl?: string;
  requestHost?: string | null;
  cartCount?: number;
}

const {
  data,
  productsResult,
  tenantName,
  themeTokens,
  platformApiBaseUrl = "http://localhost:3000",
  requestHost = null,
  cartCount = 0,
} = Astro.props;

const templateData = parseClassicData(data, tenantName);
const theme = parseClassicTheme(themeTokens);
const shellTheme = classicShellTheme(theme);
const products: StoreProduct[] = "products" in productsResult ? productsResult.products : [];
const storeError = "message" in productsResult ? productsResult : null;
const logoUrl = isImageUrl(templateData.header.logoAssetId)
  ? templateData.header.logoAssetId
  : null;
const heroImageUrl = isImageUrl(templateData.home.hero.imageAssetId)
  ? templateData.home.hero.imageAssetId
  : null;

const collectionsResult = await listStoreCollections({
  platformApiBaseUrl,
  requestHost,
  limit: 12,
});
const collections =
  !isStoreError(collectionsResult) ? collectionsResult.collections : [];
const showCollections =
  templateData.home.collectionsStrip?.enabled !== false && collections.length > 0;
---

<Layout
  tenantName={tenantName}
  cartCount={cartCount}
  theme={shellTheme}
  announcement={templateData.announcement?.enabled ? templateData.announcement.text : null}
  nav={templateData.header.navigation}
  logoUrl={logoUrl}
  footerPhone={templateData.footer.phone}
  footerAddress={templateData.footer.address}
  footerBlurb={templateData.footer.blurb}
  footerLinks={templateData.footer.socialLinks}
  currentPath="/"
>
  <section class="at-hero at-reveal">
    <div class="at-hero-copy">
      <h1 class="at-h1">{templateData.home.hero.title}</h1>
      {
        templateData.home.hero.subtitle ? (
          <p class="at-lede">{templateData.home.hero.subtitle}</p>
        ) : null
      }
      <div class="at-actions">
        <a class="at-btn" href={templateData.home.hero.primaryCtaHref}>
          {templateData.home.hero.primaryCtaLabel}
        </a>
        {
          templateData.home.hero.secondaryCtaLabel && templateData.home.hero.secondaryCtaHref ? (
            <a class="at-btn at-btn-ghost" href={templateData.home.hero.secondaryCtaHref}>
              {templateData.home.hero.secondaryCtaLabel}
            </a>
          ) : (
            <a class="at-btn at-btn-ghost" href="/products">
              Browse all
            </a>
          )
        }
      </div>
    </div>
    {
      heroImageUrl ? (
        <figure class="at-hero-media at-bezel">
          <div class="at-bezel-inner">
            <img src={heroImageUrl} alt="" loading="eager" />
          </div>
        </figure>
      ) : (
        <div class="at-hero-media at-bezel" aria-hidden="true">
          <div class="at-bezel-inner at-hero-placeholder">
            <span>{tenantName}</span>
          </div>
        </div>
      )
    }
  </section>

  {
    showCollections ? (
      <section class="at-block at-reveal" aria-labelledby="collections-title">
        <div class="at-section-head">
          <h2 class="at-h2" id="collections-title">
            {templateData.home.collectionsStrip?.title ?? "Collections"}
          </h2>
          <a class="at-text-link" href="/products">
            View all
          </a>
        </div>
        <div class="at-strip">
          {collections.map((collection) => (
            <a href={`/products?collection=${encodeURIComponent(collection.id)}`}>
              {collection.title ?? "Collection"}
            </a>
          ))}
        </div>
      </section>
    ) : null
  }

  <section class="at-block at-reveal" id="products" aria-labelledby="featured-title">
    <div class="at-section-head">
      <h2 class="at-h2" id="featured-title">{templateData.home.featuredProducts.title}</h2>
      {!storeError && products.length > 0 ? (
        <p class="at-muted" style="margin:0">{products.length} available</p>
      ) : null}
    </div>

    {
      storeError ? (
        <div class="at-notice">
          <p>
            <strong>Products could not be loaded</strong>
          </p>
          <p class="at-muted">Please try again in a moment.</p>
        </div>
      ) : products.length > 0 ? (
        <>
          <ul class="at-grid">
            {products.map((product) => {
              const inStock = product.variants.some((v) => v.inStock) || product.variants.length === 0;
              return (
                <li>
                  <a
                    class="at-card"
                    href={
                      product.handle
                        ? `/products/${encodeURIComponent(product.handle)}`
                        : "/products"
                    }
                  >
                    <div class="at-card-media">
                      {product.thumbnail ? (
                        <img src={product.thumbnail} alt="" loading="lazy" />
                      ) : null}
                      {!inStock ? <span class="at-badge-corner">Sold out</span> : null}
                    </div>
                    <h3 class="at-card-title">{product.title ?? "Product"}</h3>
                    {product.collectionTitle ? (
                      <p class="at-card-meta">{product.collectionTitle}</p>
                    ) : null}
                    <p class="at-card-price">
                      {formatMoney(product.priceAmount, product.currencyCode)}
                    </p>
                  </a>
                </li>
              );
            })}
          </ul>
          <div class="at-actions">
            <a class="at-btn at-btn-ghost" href="/products">
              View all products
            </a>
          </div>
        </>
      ) : (
        <div class="at-notice">
          <p>
            <strong>No products yet</strong>
          </p>
          <p class="at-muted">Check back soon for new arrivals.</p>
        </div>
      )
    }
  </section>

  <section class="at-trust at-reveal" aria-label="Why shop here">
    <div class="at-trust-item">
      <strong>Local delivery</strong>
      <p>Delivery and pickup available at checkout.</p>
    </div>
    <div class="at-trust-item">
      <strong>Cash on delivery</strong>
      <p>Pay when your order arrives.</p>
    </div>
    <div class="at-trust-item">
      <strong>Clear options</strong>
      <p>Choose size, color, and more before you buy.</p>
    </div>
  </section>
</Layout>
