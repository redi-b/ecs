{
	auto_https off
}

# Local dev proxy only. Do NOT long-cache /_next/static here —
# Turbopack/HMR reuses chunk URLs; immutable cache causes stale JS,
# hydration mismatches, and hard-refresh-only updates.
# Production caching lives in infra/dokploy/Caddyfile + dashboard next.config (prod).

http://api.lvh.me {
	reverse_proxy host.docker.internal:3000
}

http://dashboard.lvh.me {
	reverse_proxy host.docker.internal:3001
}

http://*.lvh.me {
	@dashboardAssets path /_next/* /__nextjs* /favicon.ico
	handle @dashboardAssets {
		reverse_proxy host.docker.internal:3001
	}

	@admin path /admin*
	handle @admin {
		reverse_proxy host.docker.internal:3001
	}

	@api path /api/*
	handle @api {
		uri strip_prefix /api
		reverse_proxy host.docker.internal:3000
	}

	handle {
		reverse_proxy host.docker.internal:4321
	}
}
