---
import ProductCard from "../../components/commerce/ProductCard.astro";
import StoreShell from "../../components/shell/StoreShell.astro";
import type { StoreCategory, StoreCollection, StoreProduct } from "../../lib/commerce/types";
import type { ShellTheme } from "../../lib/theme";

interface Props {
  tenantName: string;
  cartCount: number;
  primaryColor?: string;
  theme?: ShellTheme;
  currentPath?: string;
  products: StoreProduct[];
  errorMessage?: string | null;
  hasPrev: boolean;
  hasNext: boolean;
  prevHref?: string;
  nextHref?: string;
  /** Optional filters (used by premium templates; ignored by classic shell). */
  collections?: StoreCollection[];
  categories?: StoreCategory[];
  filters?: {
    q?: string;
    collectionId?: string;
    categoryId?: string;
    order?: string;
  };
  totalCount?: number;
}

const {
  tenantName,
  cartCount,
  primaryColor,
  theme,
  currentPath = "/products",
  products,
  errorMessage,
  hasPrev,
  hasNext,
  prevHref,
  nextHref,
} = Astro.props;
---

<StoreShell
  tenantName={tenantName}
  cartCount={cartCount}
  title="Products"
  primaryColor={primaryColor}
  theme={theme}
  currentPath={currentPath}
>
  <p class="sf-eyebrow">Catalog</p>
  <h1 class="sf-title">Products</h1>
  <p class="sf-lede">Browse everything available in this shop.</p>

  {
    errorMessage ? (
      <div class="sf-notice sf-notice-error" role="alert">
        Could not load products: {errorMessage}
      </div>
    ) : products.length === 0 ? (
      <div class="sf-notice" role="status">
        <p><strong>No products yet.</strong></p>
        <p class="sf-muted">Check back soon — this shop is still stocking the shelves.</p>
      </div>
    ) : (
      <ul class="sf-grid">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </ul>
    )
  }

  {
    (hasPrev || hasNext) && (
      <div class="sf-actions">
        {hasPrev && prevHref && (
          <a class="sf-btn sf-btn-secondary" href={prevHref}>
            Previous
          </a>
        )}
        {hasNext && nextHref && (
          <a class="sf-btn sf-btn-secondary" href={nextHref}>
            Next
          </a>
        )}
      </div>
    )
  }
</StoreShell>
