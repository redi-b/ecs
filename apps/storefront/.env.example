PLATFORM_API_BASE_URL=http://localhost:3000
STORE_API_BASE_PATH=/store
# Public shop host suffix (CSRF allowedDomains / multi-tenant *.domain).
STOREFRONT_BASE_DOMAIN=lvh.me
# Alias used by some deploy configs (same idea as STOREFRONT_BASE_DOMAIN).
# STOREFRONT_PUBLIC_BASE_DOMAIN=lvh.me

# --- Public HTML cache (Astro SSR + Redis; multi-tenant keys include Host) ---
# Required for cache hits across restarts / multiple instances. Without Redis,
# the storefront still serves pages (fail-open) but does not cache HTML.
REDIS_URL=redis://localhost:6379
# Optional Redis key prefix for HTML entries and tag sets.
STOREFRONT_CACHE_PREFIX=ecs:sf:cache
# Shared secret for POST /internal/cache-purge (platform-api publish + catalog writes).
# Must match platform-api STOREFRONT_CACHE_PURGE_SECRET. Leave empty to disable purge auth
# (platform skips purge when its secret is unset).
STOREFRONT_CACHE_PURGE_SECRET=dev-storefront-cache-purge
