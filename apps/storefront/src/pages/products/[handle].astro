---
import StoreUnavailable from "../../components/shell/StoreUnavailable.astro";
import { listStoreProducts, getStoreProductByHandle } from "../../lib/commerce/products";
import { isStoreError } from "../../lib/commerce/result";
import type { StoreProduct } from "../../lib/commerce/types";
import { loadPageContext } from "../../lib/page-context";
import { getPrimaryColor, themeFromTokens } from "../../lib/theme";
import { resolveRendererSlot } from "../../templates/registry";

const ctx = await loadPageContext(Astro.request);
const handle = Astro.params.handle ?? "";

if (!ctx.ok) {
  Astro.response.status = ctx.status;
}

const productResult =
  ctx.ok && handle
    ? await getStoreProductByHandle({
        handle,
        platformApiBaseUrl: ctx.platformApiBaseUrl,
        requestHost: ctx.requestHost,
        regionId: ctx.config.commerce.regionId,
      })
    : null;

if (productResult && isStoreError(productResult)) {
  Astro.response.status = productResult.status;
}

const product: StoreProduct | null =
  productResult && !isStoreError(productResult) ? productResult.product : null;

let relatedProducts: StoreProduct[] = [];
if (ctx.ok && product?.collectionId) {
  const relatedResult = await listStoreProducts({
    platformApiBaseUrl: ctx.platformApiBaseUrl,
    requestHost: ctx.requestHost,
    regionId: ctx.config.commerce.regionId,
    collectionId: product.collectionId,
    limit: 8,
  });
  if (!isStoreError(relatedResult)) {
    relatedProducts = relatedResult.products
      .filter((item) => item.id !== product.id)
      .slice(0, 4);
  }
} else if (ctx.ok && product) {
  const relatedResult = await listStoreProducts({
    platformApiBaseUrl: ctx.platformApiBaseUrl,
    requestHost: ctx.requestHost,
    regionId: ctx.config.commerce.regionId,
    limit: 8,
  });
  if (!isStoreError(relatedResult)) {
    relatedProducts = relatedResult.products
      .filter((item) => item.id !== product.id)
      .slice(0, 4);
  }
}

const Product = ctx.ok ? resolveRendererSlot(ctx.config.storefront.templateKey, "Product") : null;
---

{
  !ctx.ok || !Product ? (
    <StoreUnavailable message={ctx.ok ? "Template unavailable" : ctx.message} />
  ) : (
    <Product
      tenantName={ctx.config.tenant.name}
      cartCount={ctx.cartCount}
      primaryColor={getPrimaryColor(ctx.config.storefront.themeTokens)}
      theme={themeFromTokens(ctx.config.storefront.themeTokens)}
      currentPath="/products"
      product={product}
      handle={handle}
      notice={Astro.url.searchParams.get("notice")}
      error={Astro.url.searchParams.get("error")}
      relatedProducts={relatedProducts}
    />
  )
}
