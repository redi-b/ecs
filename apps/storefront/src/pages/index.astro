---
import { listStoreProducts } from "../lib/platform-store";
import { getPublishedStorefrontConfig } from "../lib/storefront-config";
import { getStorefrontRenderer } from "../templates/registry";

const platformApiBaseUrl = process.env.PLATFORM_API_BASE_URL ?? "http://localhost:3000";
const requestHost =
  Astro.request.headers.get("x-forwarded-host") ?? Astro.request.headers.get("host");
const configResult = await getPublishedStorefrontConfig({
  platformApiBaseUrl,
  requestHost,
});

// biome-ignore lint/correctness/noUnusedVariables: Used by the Astro template below.
const productsResult = configResult.ok
  ? await listStoreProducts({
      platformApiBaseUrl,
      requestHost,
    })
  : { ok: false as const, status: configResult.status, message: configResult.message };
const renderer = configResult.ok
  ? getStorefrontRenderer(configResult.config.storefront.templateKey)
  : undefined;
const Home = renderer?.Home;

if (!configResult.ok) {
  Astro.response.status = configResult.status;
} else if (!Home) {
  Astro.response.status = 500;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{configResult.ok ? configResult.config.tenant.name : "Store unavailable"}</title>
  </head>
  <body>
    {
      !configResult.ok ? (
        <main class="unavailable">
          <p class="eyebrow">Store unavailable</p>
          <h1>This storefront is not available.</h1>
          <p>{configResult.message}</p>
        </main>
      ) : Home ? (
        <Home
          data={configResult.config.storefront.data}
          productsResult={productsResult}
          tenantName={configResult.config.tenant.name}
          themeTokens={configResult.config.storefront.themeTokens}
        />
      ) : (
        <main class="unavailable">
          <p class="eyebrow">Configuration error</p>
          <h1>This storefront template is not supported.</h1>
          <p>{configResult.config.storefront.templateKey}</p>
        </main>
      )
    }
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #f8fafc;
    color: #111827;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .unavailable {
    margin: 0 auto;
    max-width: 720px;
    padding: 72px 20px;
  }

  .eyebrow {
    color: #0f766e;
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4.75rem);
    letter-spacing: 0;
    line-height: 0.98;
    margin-bottom: 20px;
  }

  p {
    color: #4b5563;
    font-size: 1.125rem;
    line-height: 1.7;
  }
</style>
