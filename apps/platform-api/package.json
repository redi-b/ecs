{
  "name": "@ecs/platform-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "dev:worker": "NODE_ENV=development tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "sync:storefront-templates": "tsx src/sync-storefront-templates.ts",
    "seed:demo": "tsx src/seeds/demo-seed.ts",
    "seed:demo:clean": "tsx src/seeds/demo-seed.ts --clean",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@ecs/config": "workspace:*",
    "@ecs/contracts": "workspace:*",
    "@ecs/db": "workspace:*",
    "@ecs/logger": "workspace:*",
    "@ecs/storefront-templates": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "pg": "^8.13.0",
    "tsx": "^4.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
