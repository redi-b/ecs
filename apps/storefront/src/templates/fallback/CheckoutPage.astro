---
import StoreShell from "../../components/shell/StoreShell.astro";
import type {
  StoreCart,
  StoreDeliveryOptions,
  StorePaymentOptions,
  StoreShippingOption,
} from "../../lib/commerce/types";
import { formatMoney } from "../../lib/money";
import type { ShellTheme } from "../../lib/theme";

interface Props {
  tenantName: string;
  cartCount: number;
  primaryColor?: string;
  theme?: ShellTheme;
  currentPath?: string;
  cart: StoreCart | null;
  delivery: StoreDeliveryOptions | null;
  payment: StorePaymentOptions;
  shippingOptions: StoreShippingOption[];
  shippingError?: string | null;
  error?: string | null;
}

const {
  tenantName,
  cartCount,
  primaryColor,
  theme,
  currentPath = "/checkout",
  cart,
  delivery,
  payment,
  shippingOptions,
  shippingError,
  error,
} = Astro.props;

const items = cart?.items ?? [];
const deliveryEnabled = delivery?.deliveryEnabled === true;
const pickupEnabled = delivery?.pickupEnabled === true;
const fulfillmentAvailable = deliveryEnabled || pickupEnabled;
const phoneRequired = delivery?.phoneConfirmationRequired !== false;
const deliveryChoiceDefault = deliveryEnabled ? "delivery" : pickupEnabled ? "pickup" : "delivery";
const paidOptions = shippingOptions.filter(
  (option) => (option.amount == null || option.amount > 0) && !/pickup|collect/i.test(option.name ?? ""),
);
const freePickupOptions = shippingOptions.filter(
  (option) =>
    (option.amount != null && option.amount === 0) || /pickup|collect/i.test(option.name ?? ""),
);
const freePickupOption = freePickupOptions[0] ?? null;
const deliveryFeeOptions = paidOptions.length > 0 ? paidOptions : shippingOptions;
const canPlaceOrder =
  items.length > 0 &&
  fulfillmentAvailable &&
  (deliveryChoiceDefault === "pickup"
    ? Boolean(freePickupOption) || shippingOptions.length > 0
    : deliveryFeeOptions.length > 0);
---

<StoreShell
  tenantName={tenantName}
  cartCount={cartCount}
  title="Checkout"
  primaryColor={primaryColor}
  theme={theme}
  currentPath={currentPath}
>
  <p class="sf-eyebrow">Almost there</p>
  <h1 class="sf-title">Checkout</h1>

  {
    error && (
      <div class="sf-notice sf-notice-error" role="alert">
        {error}
      </div>
    )
  }

  {
    items.length === 0 ? (
      <div class="sf-notice" role="status">
        <p>
          <strong>Your cart is empty.</strong>
        </p>
        <a class="sf-btn" href="/products">
          Browse products
        </a>
      </div>
    ) : (
      <div class="sf-checkout-layout">
        <div>
          {shippingOptions.length === 0 && (
            <div class="sf-notice" role="status">
              <p>
                <strong>Delivery options are not available yet.</strong>
              </p>
              <p class="sf-muted">
                Please go back to your cart and try checkout again in a moment.
              </p>
              <div class="sf-actions">
                <a class="sf-btn sf-btn-secondary" href="/cart">
                  Back to cart
                </a>
                <a class="sf-btn sf-btn-secondary" href="/products">
                  Keep shopping
                </a>
              </div>
            </div>
          )}

          <form method="post" action="/actions/checkout/cod" class="sf-panel sf-stack">
            <h2>Contact & delivery</h2>
            <div class="sf-field">
              <label for="name">Full name</label>
              <input id="name" name="name" required autocomplete="name" />
            </div>
            <div class="sf-field">
              <label for="phone">Phone{phoneRequired ? "" : " (optional)"}</label>
              <input
                id="phone"
                name="phone"
                required={phoneRequired}
                autocomplete="tel"
              />
            </div>
            <div class="sf-field">
              <label for="email">Email (optional)</label>
              <input id="email" name="email" type="email" autocomplete="email" />
            </div>

            {
              !fulfillmentAvailable ? (
                <div class="sf-notice" role="status">
                  <p>
                    <strong>Delivery and pickup are unavailable.</strong>
                  </p>
                  <p class="sf-muted">This shop is not accepting orders for delivery or pickup right now.</p>
                </div>
              ) : null
            }

            <div class="sf-field">
              <label for="deliveryChoice">Method</label>
              <select
                id="deliveryChoice"
                name="deliveryChoice"
                required
                disabled={!fulfillmentAvailable}
              >
                {deliveryEnabled && (
                  <option value="delivery" selected={deliveryChoiceDefault === "delivery"}>
                    Delivery
                  </option>
                )}
                {pickupEnabled && (
                  <option value="pickup" selected={deliveryChoiceDefault === "pickup"}>
                    Pickup
                  </option>
                )}
              </select>
            </div>

            <div
              class="sf-field"
              data-delivery-only
              hidden={deliveryChoiceDefault !== "delivery"}
              style={deliveryChoiceDefault !== "delivery" ? "display:none" : undefined}
            >
              <label for="address1">Address</label>
              <input
                id="address1"
                name="address1"
                required={deliveryChoiceDefault === "delivery"}
                disabled={deliveryChoiceDefault !== "delivery"}
                autocomplete="street-address"
              />
            </div>
            <div
              class="sf-field"
              data-delivery-only
              hidden={deliveryChoiceDefault !== "delivery"}
              style={deliveryChoiceDefault !== "delivery" ? "display:none" : undefined}
            >
              <label for="city">City</label>
              <input
                id="city"
                name="city"
                required={deliveryChoiceDefault === "delivery"}
                disabled={deliveryChoiceDefault !== "delivery"}
                autocomplete="address-level2"
                value="Addis Ababa"
              />
            </div>
            <div
              class="sf-field"
              data-delivery-only
              hidden={deliveryChoiceDefault !== "delivery"}
              style={deliveryChoiceDefault !== "delivery" ? "display:none" : undefined}
            >
              <label for="landmark">
                Landmark{delivery?.landmarkRequired ? " (required)" : " (optional)"}
              </label>
              <input
                id="landmark"
                name="landmark"
                required={Boolean(delivery?.landmarkRequired) && deliveryChoiceDefault === "delivery"}
                disabled={deliveryChoiceDefault !== "delivery"}
                data-landmark-required={delivery?.landmarkRequired ? "true" : "false"}
              />
            </div>

            {delivery?.notesEnabled !== false && (
              <div class="sf-field">
                <label for="notes">Notes (optional)</label>
                <textarea id="notes" name="notes" />
              </div>
            )}

            <div
              class="sf-field"
              data-fee-delivery
              hidden={deliveryChoiceDefault === "pickup"}
              style={deliveryChoiceDefault === "pickup" ? "display:none" : undefined}
            >
              <label for="shippingOptionId">Delivery fee</label>
              {deliveryFeeOptions.length > 0 ? (
                <select
                  id="shippingOptionId"
                  name="shippingOptionId"
                  required={deliveryChoiceDefault === "delivery"}
                  disabled={deliveryChoiceDefault === "pickup"}
                >
                  {deliveryFeeOptions.map((option) => {
                    const rawName = option.name?.trim() || "Standard";
                    const name = /shipping/i.test(rawName) ? "Standard" : rawName;
                    return (
                      <option value={option.id}>
                        {name +
                          (option.amount != null
                            ? ` · ${formatMoney(option.amount, option.currencyCode ?? cart?.currencyCode)}`
                            : "")}
                      </option>
                    );
                  })}
                </select>
              ) : (
                <p class="sf-muted">No delivery fee option is available yet.</p>
              )}
            </div>
            <div
              class="sf-field"
              data-fee-pickup
              hidden={deliveryChoiceDefault !== "pickup"}
              style={deliveryChoiceDefault !== "pickup" ? "display:none" : undefined}
            >
              <label>Pickup fee</label>
              <p class="sf-muted">Free · collect at the shop</p>
              {freePickupOption ? (
                <input type="hidden" name="shippingOptionId" value={freePickupOption.id} data-pickup-option />
              ) : deliveryFeeOptions[0] ? (
                <input type="hidden" name="shippingOptionId" value={deliveryFeeOptions[0].id} data-pickup-option />
              ) : null}
            </div>

            <div class="sf-actions">
              {payment.cod && canPlaceOrder && (
                <button class="sf-btn sf-btn-accent" type="submit">
                  Place order · Pay on delivery
                </button>
              )}
              {payment.chapa && canPlaceOrder && (
                <button
                  class="sf-btn"
                  type="submit"
                  formaction="/actions/checkout/chapa"
                >
                  Pay with Chapa
                </button>
              )}
              {!payment.chapa && (
                <p class="sf-muted">
                  Online payment is not available for this order. You can still pay on delivery when
                  that option is offered.
                </p>
              )}
              <a class="sf-btn sf-btn-secondary" href="/cart">
                Back to cart
              </a>
            </div>
          </form>
        </div>

        <aside class="sf-panel" aria-label="Order summary">
          <h2>Order summary</h2>
          {
            items.map((item) => (
              <div class="sf-summary-line">
                <span>
                  {item.quantity}× {item.title ?? "Item"}
                </span>
                <span>{formatMoney(item.total ?? item.unitPrice, cart?.currencyCode)}</span>
              </div>
            ))
          }
          <div class="sf-summary-line total">
            <span>Total</span>
            <span>{formatMoney(cart?.total ?? cart?.itemTotal, cart?.currencyCode)}</span>
          </div>
        </aside>
      </div>
    )
  }

  <script is:inline>
    (function () {
      var select = document.getElementById("deliveryChoice");
      if (!select) return;
      function setVisible(el, on) {
        if (!el) return;
        el.hidden = !on;
        el.style.display = on ? "" : "none";
      }
      function sync() {
        var isDelivery = select.value === "delivery";
        document.querySelectorAll("[data-delivery-only]").forEach(function (el) {
          setVisible(el, isDelivery);
          el.querySelectorAll("input, textarea, select").forEach(function (field) {
            field.disabled = !isDelivery;
            if (field.id === "landmark") {
              var need = field.getAttribute("data-landmark-required") === "true";
              field.required = isDelivery && need;
            } else {
              field.required = isDelivery;
            }
            if (!isDelivery) {
              field.removeAttribute("required");
            }
          });
        });
        setVisible(document.querySelector("[data-fee-delivery]"), isDelivery);
        setVisible(document.querySelector("[data-fee-pickup]"), !isDelivery);
        var feeSelect = document.getElementById("shippingOptionId");
        if (feeSelect) {
          feeSelect.disabled = !isDelivery;
          feeSelect.required = isDelivery;
          if (!isDelivery) feeSelect.removeAttribute("required");
        }
        document.querySelectorAll("[data-pickup-option]").forEach(function (input) {
          input.disabled = isDelivery;
        });
      }
      select.addEventListener("change", sync);
      sync();
    })();
  </script>
</StoreShell>
