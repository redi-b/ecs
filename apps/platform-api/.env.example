SERVICE_NAME=platform-api
PORT=3000
PLATFORM_DATABASE_URL=postgres://ecs:ecs@localhost:5432/platform_db
PLATFORM_DATABASE_SSL=false
PLATFORM_DATABASE_POOL_MAX=5
PLATFORM_DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# Used by demo-seed to backdate orders (SQL). Local: localhost; Docker/Dokploy: postgres host.
MEDUSA_DATABASE_URL=postgres://ecs:ecs@localhost:5432/medusa_db
MEDUSA_DATABASE_SSL=false
MEDUSA_INTERNAL_URL=http://localhost:9000
# Optional. Empty → auto-bootstrap via Medusa internal route + encrypted DB storage.
MEDUSA_ADMIN_API_TOKEN=
# Optional. Encrypts platform_system_secrets (falls back to BETTER_AUTH_SECRET).
PLATFORM_SECRETS_ENCRYPTION_KEY=
PLATFORM_INTERNAL_API_TOKEN=development-platform-internal-token
REDIS_URL=redis://localhost:6379
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Optional: secret for setWebhook secret_token header
TELEGRAM_WEBHOOK_SECRET=
# Local connect: long-poll Telegram updates so /start works without a public webhook.
# Default on in development. Set 0 to force webhook-only. Production should leave unset/off.
TELEGRAM_POLLING=1
# Real email delivery (Resend). Both required for merchant email alerts.
RESEND_API_KEY=
EMAIL_FROM=
MEDIA_STORAGE_PROVIDER=s3
# Local: SeaweedFS S3 on :9002 (see infra/compose). Path-style + public base URL.
MEDIA_S3_ENDPOINT=http://localhost:9002
# Optional: server-side PutObject (demo-seed). Local can omit (same as ENDPOINT).
# Docker/Dokploy: http://seaweedfs:8333
# MEDIA_S3_INTERNAL_ENDPOINT=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=ecs-media
MEDIA_S3_ACCESS_KEY_ID=ecs
MEDIA_S3_SECRET_ACCESS_KEY=ecs-media-development
MEDIA_S3_PUBLIC_BASE_URL=http://localhost:9002/ecs-media
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_UPLOAD_URL_TTL_SECONDS=900
# --- Chapa (commerce checkout + platform subscription billing) ---
# Secret used to initialize checkout and to VERIFY before applying paid state.
CHAPA_SECRET_KEY=
CHAPA_API_URL=https://api.chapa.co/v1
# Public HTTPS base Chapa can reach for callback_url (server notify).
# Local lvh.me is NOT reachable from Chapa — use a tunnel in dev, or rely on
# billing return_url confirm + billing.reconcile-payments worker.
PLATFORM_PUBLIC_BASE_URL=http://api.lvh.me
# Demo owner emails are often *.local (Chapa rejects them). Real mailbox for test pays.
CHAPA_FALLBACK_EMAIL=payments@example.com
# Worker: re-verify pending ecs_bill_* invoices (ms). Default 5m. 0 = disable schedule.
BILLING_RECONCILE_INTERVAL_MS=300000
# Worker: renewals / past_due / scheduled free downgrades (ms). Default 1h. 0 = disable.
BILLING_LIFECYCLE_INTERVAL_MS=3600000

BETTER_AUTH_SECRET=development-ecs-auth-secret-change-before-production
BETTER_AUTH_URL=http://api.lvh.me
BETTER_AUTH_COOKIE_DOMAIN=.lvh.me
# Cookie name prefix (Better Auth docs: advanced.cookiePrefix). Default: ecs → ecs.session_token
BETTER_AUTH_COOKIE_PREFIX=ecs
BETTER_AUTH_TRUSTED_ORIGINS=http://dashboard.lvh.me,http://*.lvh.me,http://*.lvh.me:3001
