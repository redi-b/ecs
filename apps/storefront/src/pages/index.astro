---
import { classicV1DataSchema } from "@ecs/storefront-templates";

import {
  getStoreProductsByIds,
  listStoreProducts,
} from "../lib/commerce/products";
import { isStoreError } from "../lib/commerce/result";
import type { StoreProduct } from "../lib/commerce/types";
import { applyCatalogCache, CATALOG_CACHE_TTL } from "../lib/http-cache";
import { loadPageContext } from "../lib/page-context";
import { getStorefrontRenderer } from "../templates/registry";

const ctx = await loadPageContext(Astro.request, { skipCart: true });

const parsedData = ctx.ok
  ? classicV1DataSchema.safeParse(ctx.config.storefront.data)
  : null;
const homeData = parsedData?.success ? parsedData.data : null;

let featuredProducts: StoreProduct[] = [];
let collectionProducts: StoreProduct[] = [];
let productsError: string | null = null;

if (ctx.ok && homeData) {
  const featured = homeData.home.featuredProducts;
  if (featured.enabled !== false) {
    const limit = featured.limit ?? 8;
    if (featured.productIds.length > 0) {
      const result = await getStoreProductsByIds({
        platformApiBaseUrl: ctx.platformApiBaseUrl,
        requestHost: ctx.requestHost,
        regionId: ctx.config.commerce.regionId,
        productIds: featured.productIds.slice(0, limit),
      });
      if (isStoreError(result)) {
        productsError = result.message;
      } else {
        featuredProducts = result.products;
      }
    } else {
      const result = await listStoreProducts({
        platformApiBaseUrl: ctx.platformApiBaseUrl,
        requestHost: ctx.requestHost,
        regionId: ctx.config.commerce.regionId,
        limit,
      });
      if (isStoreError(result)) {
        productsError = result.message;
      } else {
        featuredProducts = result.products;
      }
    }
  }

  const featuredCollection = homeData.home.featuredCollection;
  if (featuredCollection?.enabled && featuredCollection.collectionId?.trim()) {
    const result = await listStoreProducts({
      platformApiBaseUrl: ctx.platformApiBaseUrl,
      requestHost: ctx.requestHost,
      regionId: ctx.config.commerce.regionId,
      collectionId: featuredCollection.collectionId.trim(),
      limit: featuredCollection.limit ?? 8,
    });
    if (!isStoreError(result)) {
      collectionProducts = result.products;
    }
  }
}

const productsResult =
  productsError != null
    ? { ok: false as const, status: 502, message: productsError }
    : { products: featuredProducts };

const renderer = ctx.ok ? getStorefrontRenderer(ctx.config.storefront.templateKey) : undefined;
const Home = renderer?.Home as
  | ((props: Record<string, unknown>) => unknown)
  | undefined;

if (!ctx.ok) {
  Astro.response.status = ctx.status;
} else if (!Home) {
  Astro.response.status = 500;
} else {
  // Public catalog HTML — cart badge deferred (Layout deferCartCount).
  applyCatalogCache(Astro.cache, {
    tenantId: ctx.config.tenant.id,
    publishedRevisionId: ctx.config.storefront.publishedRevisionId,
    templateKey: ctx.config.storefront.templateKey,
    maxAge: CATALOG_CACHE_TTL.home.maxAge,
    swr: CATALOG_CACHE_TTL.home.swr,
  });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{ctx.ok ? ctx.config.tenant.name : "Shop unavailable"}</title>
  </head>
  <body>
    {
      !ctx.ok ? (
        <main class="unavailable">
          <h1>{ctx.message}</h1>
        </main>
      ) : Home ? (
        <Home
          data={ctx.config.storefront.data}
          productsResult={productsResult}
          collectionProducts={collectionProducts}
          tenantName={ctx.config.tenant.name}
          themeTokens={ctx.config.storefront.themeTokens}
          platformApiBaseUrl={ctx.platformApiBaseUrl}
          requestHost={ctx.requestHost}
          deferCartCount={true}
        />
      ) : (
        <main class="unavailable">
          <h1>Please try again later.</h1>
        </main>
      )
    }
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
  }

  .unavailable {
    margin: 0 auto;
    max-width: 36rem;
    padding: 20vh 1.5rem 4rem;
    font-family:
      Outfit, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  h1 {
    margin: 0;
    color: #111827;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
</style>
