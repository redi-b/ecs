---
import { listStoreProducts } from "../lib/platform-store";
import { loadPageContext } from "../lib/page-context";
import { getStorefrontRenderer } from "../templates/registry";

const ctx = await loadPageContext(Astro.request);

const productsResult = ctx.ok
  ? await listStoreProducts({
      platformApiBaseUrl: ctx.platformApiBaseUrl,
      requestHost: ctx.requestHost,
      regionId: ctx.config.commerce.regionId,
      limit: 8,
    })
  : { ok: false as const, status: ctx.status, message: ctx.message };

const renderer = ctx.ok ? getStorefrontRenderer(ctx.config.storefront.templateKey) : undefined;
const Home = renderer?.Home as
  | ((props: Record<string, unknown>) => unknown)
  | undefined;

if (!ctx.ok) {
  Astro.response.status = ctx.status;
} else if (!Home) {
  Astro.response.status = 500;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{ctx.ok ? ctx.config.tenant.name : "Shop unavailable"}</title>
  </head>
  <body>
    {
      !ctx.ok ? (
        <main class="unavailable">
          <h1>{ctx.message}</h1>
        </main>
      ) : Home ? (
        <Home
          data={ctx.config.storefront.data}
          productsResult={productsResult}
          tenantName={ctx.config.tenant.name}
          themeTokens={ctx.config.storefront.themeTokens}
          platformApiBaseUrl={ctx.platformApiBaseUrl}
          requestHost={ctx.requestHost}
          cartCount={ctx.cartCount}
        />
      ) : (
        <main class="unavailable">
          <h1>Please try again later.</h1>
        </main>
      )
    }
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
  }

  .unavailable {
    margin: 0 auto;
    max-width: 36rem;
    padding: 20vh 1.5rem 4rem;
    font-family:
      Outfit, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  h1 {
    margin: 0;
    color: #111827;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
</style>
