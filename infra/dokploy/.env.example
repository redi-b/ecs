IMAGE_PREFIX=ghcr.io/your-org/your-repo
IMAGE_TAG=main
BASE_DOMAIN=ecs.domain.com

POSTGRES_USER=ecs
POSTGRES_PASSWORD=replace-with-a-url-safe-password
POSTGRES_DB=ecs
PLATFORM_DATABASE_URL=postgres://ecs:replace-with-a-url-safe-password@postgres:5432/platform_db
PLATFORM_DATABASE_SSL=false
MEDUSA_DATABASE_URL=postgres://ecs:replace-with-a-url-safe-password@postgres:5432/medusa_db
MEDUSA_DATABASE_SSL=false

PLATFORM_INTERNAL_API_TOKEN=replace-with-a-long-random-value
BETTER_AUTH_SECRET=replace-with-a-long-random-value
# Session cookie brand prefix (default ecs → ecs.session_token). Keep in sync with dashboard.
BETTER_AUTH_COOKIE_PREFIX=ecs
# Shared secret: platform-api purges storefront HTML after publish + catalog writes.
# Must match storefront STOREFRONT_CACHE_PURGE_SECRET (compose injects both).
STOREFRONT_CACHE_PURGE_SECRET=replace-with-a-long-random-value
MEDUSA_JWT_SECRET=replace-with-a-long-random-value
MEDUSA_COOKIE_SECRET=replace-with-a-long-random-value
# Optional override. When empty, platform-api bootstraps a Medusa secret admin
# key and stores it encrypted in platform_system_secrets.
MEDUSA_ADMIN_API_TOKEN=
# Optional dedicated key for system secrets at rest (falls back to BETTER_AUTH_SECRET).
PLATFORM_SECRETS_ENCRYPTION_KEY=

# Object storage for product/media uploads (SeaweedFS S3 in this stack).
MEDIA_S3_ACCESS_KEY_ID=ecs
MEDIA_S3_SECRET_ACCESS_KEY=replace-with-a-strong-media-secret
MEDIA_S3_BUCKET=ecs-media
# Public endpoint used for browser presigned URLs (Caddy → seaweedfs:8333).
MEDIA_S3_ENDPOINT=https://media.ecs.domain.com
# In-network S3 API for server-side uploads (demo-seed PutObject). Required for prod seed media.
MEDIA_S3_INTERNAL_ENDPOINT=http://seaweedfs:8333
# Browser-facing public URL for objects (routed via Caddy as media.${BASE_DOMAIN}).
MEDIA_S3_PUBLIC_BASE_URL=https://media.ecs.domain.com/ecs-media
MEDIA_S3_REGION=us-east-1
MEDIA_S3_FORCE_PATH_STYLE=true
# Browser uploads come from the dashboard origin (CORS preflight).
MEDIA_S3_CORS_ALLOW_ORIGIN=https://dashboard.ecs.domain.com

# --- Merchant notifications (platform-api + platform-worker) ---
# Telegram: bot from @BotFather. Username without @. Webhook secret optional.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Email: Resend. Both required for real email alerts (else log provider).
RESEND_API_KEY=
EMAIL_FROM=alerts@ecs.domain.com

# --- Chapa (commerce checkout + platform subscription billing) ---
CHAPA_SECRET_KEY=
CHAPA_API_URL=https://api.chapa.co/v1
CHAPA_CUSTOMIZATION_TITLE=ECS Store
CHAPA_CUSTOMIZATION_DESCRIPTION=Order payment
# Fallback when merchant email is invalid for Chapa (e.g. demo *.local).
CHAPA_FALLBACK_EMAIL=payments@example.com
# Encrypt merchant store Chapa secrets at rest (AES-GCM). Prefer a dedicated key.
PAYMENTS_CREDENTIALS_ENCRYPTION_KEY=
# Public API origin is derived in compose as https://api.${BASE_DOMAIN}.
# Ensure that host is reachable from Chapa for callback_url.
# Worker billing schedules (platform-worker process; ms; 0 = disable)
BILLING_RECONCILE_INTERVAL_MS=300000
BILLING_LIFECYCLE_INTERVAL_MS=3600000

# Optional merchant support contact (dashboard payments help CTA).
# MERCHANT_SUPPORT_URL takes precedence; email is used as mailto: if URL is empty.
MERCHANT_SUPPORT_URL=
MERCHANT_SUPPORT_EMAIL=support@ecs.domain.com
