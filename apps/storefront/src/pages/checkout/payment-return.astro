---
import StoreShell from "../../components/shell/StoreShell.astro";
import { completeChapaStoreCheckout } from "../../lib/commerce/checkout";
import { isStoreError } from "../../lib/commerce/result";
import { loadPageContext } from "../../lib/page-context";
import {
  appendSetCookies,
  cartIdClearCookie,
  lastOrderSetCookie,
} from "../../lib/session/cart-cookie";

/**
 * After Chapa redirects back: platform verifies with merchant secret, then completes cart.
 * Does not trust client "success" alone.
 */
const ctx = await loadPageContext(Astro.request);
const url = Astro.url;
const txRef =
  url.searchParams.get("trx_ref") ??
  url.searchParams.get("tx_ref") ??
  url.searchParams.get("txRef") ??
  null;

let error: string | null = null;
let orderId: string | null = null;

const friendlyMessages: Record<string, string> = {
  chapa_payment_not_paid:
    "Payment is not complete yet. Finish payment in Chapa, then return here.",
  chapa_payment_not_found:
    "We could not find this payment. Contact the shop if you were charged.",
  chapa_verification_failed:
    "We could not verify payment with Chapa. Try again in a moment.",
  chapa_tx_ref_missing: "Payment reference missing. Start checkout again from your cart.",
  chapa_tx_ref_mismatch: "Payment reference did not match this cart.",
  merchant_chapa_not_configured: "Online payment is not available for this shop right now.",
};

if (!ctx.ok) {
  error = ctx.message;
  Astro.response.status = ctx.status;
} else if (!ctx.cartId) {
  error = "No cart found for this payment return. Open your cart and try checkout again.";
} else {
  const result = await completeChapaStoreCheckout({
    cartId: ctx.cartId,
    platformApiBaseUrl: ctx.platformApiBaseUrl,
    requestHost: ctx.requestHost,
    txRef,
  });

  if (isStoreError(result)) {
    error = friendlyMessages[result.message] ?? result.message;
  } else {
    orderId = result.order.id;
    const headers = new Headers({
      Location: `/order/${encodeURIComponent(result.order.id)}`,
    });
    appendSetCookies(headers, [
      cartIdClearCookie(),
      lastOrderSetCookie({
        id: result.order.id,
        total: result.order.total,
        currencyCode: result.order.currencyCode,
      }),
    ]);
    return new Response(null, { status: 303, headers });
  }
}

const storeAvailable = ctx.ok;
const tenantName = ctx.ok ? ctx.config.tenant.name : "Store";
const cartCount = ctx.ok ? ctx.cartCount : 0;
const showError = Boolean(error);
const redirectLabel = orderId ? `Redirecting... ${orderId}` : "Redirecting...";
---

{storeAvailable && (
  <StoreShell tenantName={tenantName} cartCount={cartCount} title="Payment">
    <h1 class="sf-title">Payment return</h1>
    {showError && (
      <div class="sf-notice sf-notice-error" role="alert">
        <p>{error}</p>
        <div class="sf-actions">
          <a class="sf-btn" href="/checkout">Back to checkout</a>
          <a class="sf-btn sf-btn-secondary" href="/cart">Cart</a>
        </div>
      </div>
    )}
    {!showError && <div class="sf-notice sf-notice-ok">{redirectLabel}</div>}
  </StoreShell>
)}

{!storeAvailable && (
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>Payment</title>
      <link rel="stylesheet" href="/styles/commerce.css" />
    </head>
    <body>
      <main class="sf-main">
        <div class="sf-notice sf-notice-error">
          <p>{error ?? "Store unavailable"}</p>
        </div>
      </main>
    </body>
  </html>
)}
